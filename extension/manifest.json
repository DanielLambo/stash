{
  "manifest_version": 3,
  "name": "Stash — Smart Clipboard for Power Users",
  "short_name": "Stash",
  "version": "1.0.2",
  "description": "Inline paste overlay, text expansion, smart actions, on-device encryption for secrets. Fully local — no third-party calls.",
  "homepage_url": "https://github.com/daniellambo/stash",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "alarms",
    "unlimitedStorage"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Stash",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "mac": "Alt+Shift+V"
      },
      "description": "Open Stash popup"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/hud.js",
        "content/snippet.js",
        "lib/storage.js",
        "lib/categorize.js",
        "lib/sensitive.js",
        "lib/crypto.js",
        "lib/actions.js",
        "privacy.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
